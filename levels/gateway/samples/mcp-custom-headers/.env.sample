# MCP Custom Headers Sample - Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# MCP Server Configuration
# =============================================================================

# The URL of your MCP server
# Example: https://your-mcp-server/mcp
MCP_SERVER_URL=

# =============================================================================
# Authentication Configuration
# =============================================================================

# OAuth scope for the MCP server (resource identifier)
# Format: api://<client-id>/.default
# The .default scope requests all authorized scopes for this resource
# The token will contain the actual scope (e.g., user_impersonate) from the app registration
MCP_OAUTH_SCOPE=api://your-mcp-app-client-id/.default

# Azure AD tenant ID (optional, for specific tenant authentication)
AZURE_TENANT_ID=

# =============================================================================
# Azure AI Foundry (for agent_framework_headers.py only)
# =============================================================================

# Azure AI Foundry project endpoint (only needed for agent framework sample)
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=

# Model deployment name in Azure AI Foundry
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4o

# =============================================================================
# Custom Context Headers (Optional)
# =============================================================================

# These values are used in custom headers for the sample
# In production, these would typically come from your application context
CUSTOMER_ID=demo-customer
TENANT_ID=demo-tenant
