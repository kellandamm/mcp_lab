{
  "name": "MCP Security Workshop",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/azure-cli:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/github-cli:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "postCreateCommand": "pip install uv && curl -fsSL https://aka.ms/install-azd.sh | bash && cd levels/base && uv sync",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "github.copilot",
        "github.copilot-chat",
        "ms-azuretools.azure-dev",
        "ms-azuretools.vscode-azureappservice",
        "ms-vscode.azure-account",
        "bierner.markdown-mermaid"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "forwardPorts": [8000, 8001],
  "portsAttributes": {
    "8000": {
      "label": "Vulnerable MCP Server",
      "onAutoForward": "notify"
    },
    "8001": {
      "label": "Secure MCP Server",
      "onAutoForward": "notify"
    }
  },

  "remoteUser": "vscode"
}
